<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ObsidianWidget" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/obsidian_primary</item>
        <item name="colorPrimaryDark">@color/obsidian_primary_dark</item>
        <item name="colorAccent">@color/obsidian_accent</item>
        <item name="android:windowBackground">@color/obsidian_bg</item>
        <item name="android:statusBarColor">@color/obsidian_bg</item>
        <item name="android:navigationBarColor">@color/obsidian_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.ObsidianWidget.Dialog" parent="Theme.Material3.Dark.Dialog">
        <item name="colorPrimary">@color/obsidian_primary</item>
        <item name="colorAccent">@color/obsidian_accent</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.90</item>
    </style>
</resources>
