<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Obsidian Widget"
        android:textColor="@color/obsidian_text"
        android:textSize="24sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add the widget to your home screen,\nthen tap the ⚙ icon to configure it."
        android:textColor="@color/obsidian_text_secondary"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Long-press your home screen → Widgets → Obsidian Widget"
        android:textColor="@color/obsidian_text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:alpha="0.6" />

</LinearLayout>
