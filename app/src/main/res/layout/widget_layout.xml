<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Note"
                android:textColor="@color/obsidian_text"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/widget_todo_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/obsidian_text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/widget_cycle_note"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next note"
            android:src="@drawable/ic_chevron_right"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/widget_refresh"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"
            android:src="@android:drawable/stat_notify_sync"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/widget_settings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:src="@android:drawable/ic_menu_manage"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Note Preview (no checklist) -->
    <TextView
        android:id="@+id/widget_note_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:text="@string/no_vault_selected"
        android:textColor="@color/obsidian_text_secondary"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:maxLines="10"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Checklist -->
    <ListView
        android:id="@+id/widget_checklist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:scrollbars="none"
        android:fadingEdge="vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:clipToPadding="false" />

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/widget_button_bar"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/widget_add"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/button_background"
            android:text="+ Add"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/widget_btn_capture"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:background="@drawable/button_background"
            android:text="Note"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

</LinearLayout>
